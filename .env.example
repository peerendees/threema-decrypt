# Bearer-Token, das Aufrufer (n8n) im Authorization-Header senden müssen.
# Muss identisch zu $env.DECRYPT_API_TOKEN in n8n sein.
DECRYPT_API_TOKEN=

# Optional: erlaubte Browser-Origin für CORS. Für reine Server-zu-Server-Aufrufe leer lassen.
ALLOWED_ORIGIN=

# Mistral API – wird von Supabase aus aufgerufen (nicht von n8n/Hostinger).
MISTRAL_API_KEY=
# Optional, Standard: pixtral-12b-2409
# MISTRAL_VISION_MODEL=
